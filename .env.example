# Copy to .env for local dev. Never commit real secrets.
# --- Core ---
ENV=local
LOG_LEVEL=info

# --- Postgres ---
# DATABASE_URL is the in-cluster address (compose service name, container port).
# From the host, Postgres is published on 5433 — a native Postgres owns 5432 on
# the dev machine. Host-side tools take their own URL:
#   make migrate / make seed   pass it for you
#   pytest                     TEST_DATABASE_URL, default .../localhost:5433/opd_test
#   alembic by hand            ALEMBIC_DATABASE_URL=postgresql+asyncpg://opd:opd_local_dev@localhost:5433/opd
POSTGRES_USER=opd
POSTGRES_PASSWORD=opd_local_dev
POSTGRES_DB=opd
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://opd:opd_local_dev@postgres:5432/opd

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Auth (S2) ---
# Local default is fine here; the app refuses to boot with ENV!=local unless this
# is replaced with a real secret of >=32 chars (see app/config.py).
JWT_SECRET=dev-only-insecure-secret-change-me
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=7

# --- OTP (S2) ---
# `fake` logs the code instead of sending an SMS; MSG91/Exotel land in S3.
SMS_PROVIDER=fake
# Returns the OTP in the API response so local login doesn't need the logs.
# Refused outside ENV=local — it would hand every account to any caller.
OTP_DEBUG_ECHO=true
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=30

# --- Web ---
NEXT_PUBLIC_API_BASE=http://localhost:8000

# --- Provider keys (stubbed in S1; real impls land S3) ---
GEMINI_API_KEY=
OPENAI_API_KEY=
SARVAM_API_KEY=
EXOTEL_SID=
EXOTEL_TOKEN=
META_WHATSAPP_TOKEN=
MSG91_KEY=
