# Copy to .env for local dev. Never commit real secrets.
# --- Core ---
ENV=local
LOG_LEVEL=info

# --- Postgres ---
# DATABASE_URL is the in-cluster address (compose service name, container port).
# From the host, Postgres is published on 5433 — a native Postgres owns 5432 on
# the dev machine. Host-side tools take their own URL:
#   make migrate / make seed   pass it for you
#   pytest                     TEST_DATABASE_URL, default .../localhost:5433/opd_test
#   alembic by hand            ALEMBIC_DATABASE_URL=postgresql+asyncpg://opd:opd_local_dev@localhost:5433/opd
POSTGRES_USER=opd
POSTGRES_PASSWORD=opd_local_dev
POSTGRES_DB=opd
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://opd:opd_local_dev@postgres:5432/opd

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Auth (S2) ---
# Local default is fine here; the app refuses to boot with ENV!=local unless this
# is replaced with a real secret of >=32 chars (see app/config.py).
JWT_SECRET=dev-only-insecure-secret-change-me
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=7

# --- OTP (S2) ---
# Returns the OTP in the API response so local login doesn't need the logs.
# Refused outside ENV=local — it would hand every account to any caller.
OTP_DEBUG_ECHO=true
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=30

# --- Web ---
# The browser talks to the api at its PUBLISHED host port. On a box where the api
# is not on 8000 (see API_HOST_PORT below), set this to match, e.g.
# http://localhost:18080 (testing on the box) or http://<box-ip>:18080 (over LAN,
# which then needs HTTPS for the kiosk mic). Baked into the bundle at build time.
NEXT_PUBLIC_API_BASE=http://localhost:8000
# Kiosk server-STT (V-OSS, doc 08): 1 = the chief-complaint mic records the clip and
# posts it to /kiosk/stt (local Whisper on the box — audio stays on-premises). Unset/0
# = the browser's Web Speech (Chrome ships audio to a cloud recogniser). Build-time.
NEXT_PUBLIC_KIOSK_SERVER_STT=0

# --- Host ports (docker-compose) ---------------------------------------------
# Only the *host* side of each mapping; in-cluster ports never change. Defaults
# match the dev machine. On a box that already runs nginx (80/443) or has 8000/
# 3000/5432 taken, uncomment the "busy box" values below (all shifted into 18xxx/
# 15xxx) and set NEXT_PUBLIC_API_BASE to match API_HOST_PORT.
#   POSTGRES_HOST_PORT=15432
#   REDIS_HOST_PORT=16379
#   API_HOST_PORT=18080
#   WEB_HOST_PORT=13000
#   VOICE_GW_HOST_PORT=18090
#   GRAFANA_HOST_PORT=13001
#   LOKI_HOST_PORT=13100
#   KUMA_HOST_PORT=13002
#   CADDY_HTTP_PORT=18081     # only if you run caddy; nginx keeps 80/443
#   CADDY_HTTPS_PORT=18443

# =============================================================================
# Provider layer (S3) — doc 02 §9
#
# `fake` is the deterministic in-process impl: no network, no cost, no vendor
# account. Every one of these is a config-only swap — change the value, restart,
# done (app/providers/registry.py). Outside ENV=local the app REFUSES TO BOOT on
# any `fake`: a fake SMS is an OTP that never arrives, and a fake LLM is an
# intake that answers itself.
# =============================================================================

# --- Which vendor answers each interface ---
SMS_PROVIDER=fake             # fake | msg91 | exotel
LLM_PROVIDER=fake             # fake | gemini | openai | local_vllm   (V-OSS, doc 08)
STT_PROVIDER=fake             # fake | sarvam | google | local_whisper (V-OSS)
TTS_PROVIDER=fake             # fake | sarvam | google | local_tts | voicebox (V-OSS)
REALTIME_PROVIDER=fake        # fake | gemini-live (S5/S14) | local-pipecat (S-OSS.2, needs GPU)
MESSAGING_PROVIDER=fake       # fake | meta
TELEPHONY_PROVIDER=fake       # fake | exotel

# Second choice per doc 02 §2's chains. Empty = no fallback; the tier ladder
# handles the outage instead.
LLM_FALLBACK_PROVIDER=        # openai
STT_FALLBACK_PROVIDER=        # google
TTS_FALLBACK_PROVIDER=        # google

# --- Gemini / OpenAI ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Sarvam (Indic STT/TTS, telephony-tuned) ---
SARVAM_API_KEY=
SARVAM_STT_MODEL=saarika:v2.5
SARVAM_TTS_MODEL=bulbul:v2
SARVAM_TTS_VOICE=anushka

# --- Google (STT/TTS fallback) ---
GOOGLE_API_KEY=
GOOGLE_TTS_VOICE=

# --- V-OSS: local open-source voice tier on the GPU box (doc 08) ---
# A base URL is all a local provider needs to count as "configured" — no key,
# unlike a cloud vendor. Reach the box over the WireGuard tunnel (doc 08 §4).
# Blank = not deployed; selecting a local provider without its URL reports
# unconfigured on /providers/health and fails the call over to the next tier.
LOCAL_VLLM_BASE_URL=          # e.g. http://10.8.0.2:8000/v1
LOCAL_VLLM_MODEL=qwen3-8b-awq
LOCAL_VLLM_API_KEY=           # only if a gateway fronts vLLM; usually blank
LOCAL_STT_URL=               # e.g. http://10.8.0.2:8010
LOCAL_STT_MODEL=whisper-large-v3-turbo
LOCAL_TTS_URL=               # e.g. http://10.8.0.2:8020
LOCAL_TTS_MODEL=             # bake-off winner (S-OSS.1); blank uses adapter default
LOCAL_TTS_VOICE=dhara_hi_v1  # the cloned Dhara identity (doc 08 §1)
VOICEBOX_URL=                # Voicebox REST host for batch V3-pack generation
VOICEBOX_VOICE=dhara_hi_v1
# Per-channel tier ladder + MAX_OSS_SESSIONS live in config/tiers.yaml, not here.

# --- SMS: MSG91 ---
# The DLT template must declare variables named `otp` and `minutes` — that
# naming is a contract with the vendor account (see app/auth/otp.py). MSG91 Flow
# sends the template id + variables and renders on their side; our body is not
# transmitted, so a missing template id is a hard error, not a fallback.
MSG91_KEY=
MSG91_SENDER_ID=OPDALW
MSG91_TEMPLATE_IDS={"otp_login": ""}

# --- Exotel: telephony always; SMS only if it wins the SMS decision ---
# Note: picking Exotel for SMS too means one vendor outage takes down SMS *and*
# the phone intake channel together. MSG91 keeps those failure domains apart.
EXOTEL_SID=
EXOTEL_API_KEY=
EXOTEL_TOKEN=
EXOTEL_SUBDOMAIN=api.exotel.com
EXOTEL_CALLER_ID=
EXOTEL_SMS_SENDER_ID=OPDALW
EXOTEL_DLT_ENTITY_ID=
EXOTEL_DLT_TEMPLATE_IDS={"otp_login": ""}

# --- Meta WhatsApp Cloud API ---
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=

# --- Cost guard (doc 02 §8) ---
# Daily spend cap in rupees per channel. A channel with no entry is UNCAPPED —
# deliberate, so a missing key never silently throttles a channel nobody
# budgeted for. Breach downgrades the tier (V1->V2->V3); it never blocks a call
# or turns a patient away.
COST_GUARD_ENABLED=true
DAILY_BUDGET_INR={"phone": "2000", "whatsapp": "500", "kiosk": "500", "app": "200"}
COST_GUARD_ALERT_FRACTION=0.8
COST_GUARD_OVERRIDE_TTL_SECONDS=900
# The OPD's day is IST: a UTC budget rollover would reset the cap at 05:30 IST,
# in the middle of the morning rush.
TIMEZONE=Asia/Kolkata

# --- Offline kiosk token blocks (S7, doc 01 §5) ------------------------------
# The token line is split so an offline kiosk and the server can both issue
# during an outage without colliding: online tokens stay below the base, offline
# blocks are carved at/above it. Nothing may cross the base.
KIOSK_OFFLINE_TOKEN_BASE=500
KIOSK_OFFLINE_BLOCK_SIZE=50

# --- Queue (S8, doc 03 §6) --------------------------------------------------
# Seed for the wait-time estimator before a department has finished any consults
# today; after that it uses its own observed mean. Downtime is an in-memory flag
# (coordinator toggle), not configured here.
QUEUE_DEFAULT_CONSULT_MINUTES=6
