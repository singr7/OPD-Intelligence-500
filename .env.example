# Copy to .env for local dev. Never commit real secrets.
# --- Core ---
ENV=local
LOG_LEVEL=info

# --- Postgres ---
# DATABASE_URL is the in-cluster address (compose service name, container port).
# From the host, Postgres is published on 5433 — a native Postgres owns 5432 on
# the dev machine. Host-side tools take their own URL:
#   make migrate / make seed   pass it for you
#   pytest                     TEST_DATABASE_URL, default .../localhost:5433/opd_test
#   alembic by hand            ALEMBIC_DATABASE_URL=postgresql+asyncpg://opd:opd_local_dev@localhost:5433/opd
POSTGRES_USER=opd
POSTGRES_PASSWORD=opd_local_dev
POSTGRES_DB=opd
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://opd:opd_local_dev@postgres:5432/opd

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Auth (S2) ---
# Local default is fine here; the app refuses to boot with ENV!=local unless this
# is replaced with a real secret of >=32 chars (see app/config.py).
JWT_SECRET=dev-only-insecure-secret-change-me
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=7

# --- OTP (S2) ---
# Returns the OTP in the API response so local login doesn't need the logs.
# Refused outside ENV=local — it would hand every account to any caller.
OTP_DEBUG_ECHO=true
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=30

# --- Web ---
NEXT_PUBLIC_API_BASE=http://localhost:8000

# =============================================================================
# Provider layer (S3) — doc 02 §9
#
# `fake` is the deterministic in-process impl: no network, no cost, no vendor
# account. Every one of these is a config-only swap — change the value, restart,
# done (app/providers/registry.py). Outside ENV=local the app REFUSES TO BOOT on
# any `fake`: a fake SMS is an OTP that never arrives, and a fake LLM is an
# intake that answers itself.
# =============================================================================

# --- Which vendor answers each interface ---
SMS_PROVIDER=fake             # fake | msg91 | exotel
LLM_PROVIDER=fake             # fake | gemini | openai
STT_PROVIDER=fake             # fake | sarvam | google
TTS_PROVIDER=fake             # fake | sarvam | google
REALTIME_PROVIDER=fake        # fake | gemini-live  (gemini-live lands in S5/S14)
MESSAGING_PROVIDER=fake       # fake | meta
TELEPHONY_PROVIDER=fake       # fake | exotel

# Second choice per doc 02 §2's chains. Empty = no fallback; the tier ladder
# handles the outage instead.
LLM_FALLBACK_PROVIDER=        # openai
STT_FALLBACK_PROVIDER=        # google
TTS_FALLBACK_PROVIDER=        # google

# --- Gemini / OpenAI ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Sarvam (Indic STT/TTS, telephony-tuned) ---
SARVAM_API_KEY=
SARVAM_STT_MODEL=saarika:v2.5
SARVAM_TTS_MODEL=bulbul:v2
SARVAM_TTS_VOICE=anushka

# --- Google (STT/TTS fallback) ---
GOOGLE_API_KEY=
GOOGLE_TTS_VOICE=

# --- SMS: MSG91 ---
# The DLT template must declare variables named `otp` and `minutes` — that
# naming is a contract with the vendor account (see app/auth/otp.py). MSG91 Flow
# sends the template id + variables and renders on their side; our body is not
# transmitted, so a missing template id is a hard error, not a fallback.
MSG91_KEY=
MSG91_SENDER_ID=OPDALW
MSG91_TEMPLATE_IDS={"otp_login": ""}

# --- Exotel: telephony always; SMS only if it wins the SMS decision ---
# Note: picking Exotel for SMS too means one vendor outage takes down SMS *and*
# the phone intake channel together. MSG91 keeps those failure domains apart.
EXOTEL_SID=
EXOTEL_API_KEY=
EXOTEL_TOKEN=
EXOTEL_SUBDOMAIN=api.exotel.com
EXOTEL_CALLER_ID=
EXOTEL_SMS_SENDER_ID=OPDALW
EXOTEL_DLT_ENTITY_ID=
EXOTEL_DLT_TEMPLATE_IDS={"otp_login": ""}

# --- Meta WhatsApp Cloud API ---
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=

# --- Cost guard (doc 02 §8) ---
# Daily spend cap in rupees per channel. A channel with no entry is UNCAPPED —
# deliberate, so a missing key never silently throttles a channel nobody
# budgeted for. Breach downgrades the tier (V1->V2->V3); it never blocks a call
# or turns a patient away.
COST_GUARD_ENABLED=true
DAILY_BUDGET_INR={"phone": "2000", "whatsapp": "500", "kiosk": "500", "app": "200"}
COST_GUARD_ALERT_FRACTION=0.8
COST_GUARD_OVERRIDE_TTL_SECONDS=900
# The OPD's day is IST: a UTC budget rollover would reset the cap at 05:30 IST,
# in the middle of the morning rush.
TIMEZONE=Asia/Kolkata
