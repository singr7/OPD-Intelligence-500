{
  "key": "general_medicine_routing",
  "version": 1,
  "department": "GENMED",
  "languages": ["en", "hi"],
  "title": {
    "en": "General Medicine — walk-in",
    "hi": "जनरल मेडिसिन — बिना अपॉइंटमेंट"
  },
  "root": "gm.problem",
  "nodes": [
    {
      "id": "gm.problem",
      "type": "single",
      "text": {
        "en": "What is troubling you most today?",
        "hi": "आज आपको सबसे ज़्यादा क्या तकलीफ़ है?"
      },
      "options": [
        { "id": "fever", "icon": "thermometer", "text": { "en": "Fever", "hi": "बुखार" } },
        { "id": "pain", "icon": "pain", "text": { "en": "Pain somewhere", "hi": "कहीं दर्द" } },
        { "id": "weakness", "icon": "tired", "text": { "en": "Weakness or tiredness", "hi": "कमज़ोरी या थकान" } },
        { "id": "stomach", "icon": "belly", "text": { "en": "Stomach trouble", "hi": "पेट की तकलीफ़" } },
        {
          "id": "breathing",
          "icon": "lungs",
          "text": { "en": "Trouble breathing", "hi": "साँस लेने में तकलीफ़" },
          "flag": true
        }
      ],
      "next": { "default": "gm.duration" },
      "red_flag": {
        "id": "gm.breathless",
        "severity": "urgent",
        "label": { "en": "Trouble breathing", "hi": "साँस लेने में तकलीफ़" },
        "instruction": {
          "en": "Please tell a nurse now, before you sit down. Do not wait for your turn.",
          "hi": "कृपया बैठने से पहले अभी नर्स को बताएं। अपनी बारी का इंतज़ार न करें।"
        }
      }
    },
    {
      "id": "gm.duration",
      "type": "number",
      "text": {
        "en": "For how many days?",
        "hi": "कितने दिनों से?"
      },
      "min": 0,
      "max": 3650,
      "unit": "days",
      "next": { "default": "gm.fever_temp" }
    },
    {
      "id": "gm.fever_temp",
      "type": "number",
      "text": {
        "en": "If you measured your temperature, what was it? Say 0 if you have not.",
        "hi": "अगर आपने बुखार नापा है तो कितना था? न नापा हो तो 0 बोलें।"
      },
      "min": 0,
      "max": 43,
      "unit": "C",
      "next": { "default": "gm.severity" },
      "red_flag_if": { "node": "gm.fever_temp", "op": "gte", "value": 38 },
      "red_flag": {
        "id": "gm.fever",
        "severity": "semi",
        "label": { "en": "Fever 38°C or above", "hi": "38°C या उससे ऊपर बुखार" },
        "instruction": {
          "en": "Please tell the staff at the desk that you have a fever today.",
          "hi": "कृपया डेस्क पर स्टाफ को बताएं कि आज आपको बुखार है।"
        }
      },
      "adaptive_hints": "0 means not measured, not 0°C."
    },
    {
      "id": "gm.severity",
      "type": "scale",
      "text": {
        "en": "How bad is it right now? Zero is fine, ten is the worst.",
        "hi": "अभी कितनी तकलीफ़ है? शून्य मतलब ठीक हूँ, दस मतलब सबसे ज़्यादा।"
      },
      "min": 0,
      "max": 10,
      "next": { "default": "gm.words" }
    },
    {
      "id": "gm.words",
      "type": "free_voice",
      "text": {
        "en": "Tell me in your own words what is happening.",
        "hi": "अपने शब्दों में बताएं कि क्या हो रहा है।"
      },
      "adaptive_hints": "Last node. This quote goes to the doctor verbatim."
    }
  ]
}
